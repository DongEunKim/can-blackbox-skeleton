# CAN Blackbox 설정
# 이 파일을 config.ini 로 복사한 후 값을 수정하세요.

[can]
# CAN 인터페이스 (쉼표 구분 다중 지원: vcan0,vcan1,can0)
interface = vcan0
# 로깅 주기(초) - 0이면 실시간
log_interval = 0
# 재연결 재시도 횟수 (0: 비활성화)
reconnect_max_retries = 5
# 재시도 초기 대기(초), 지수 백오프 적용
reconnect_interval_sec = 2

[logging]
# BLF 파일 저장 경로
output_dir = ./logs
# 로그 파일명 prefix (기본: CBB_)
log_prefix = CBB_
# 로테이션 최대 용량(MB) - 초과 시 새 파일 생성
rotation_max_mb = 10
# 최대 로깅 시간(분) - 경과 시 로깅 중단 (0: 무제한)
max_logging_minutes = 30

[storage]
# 최대 총 용량(MB) - 초과 시 오래된 파일 삭제
max_total_mb = 500

[watcher]
# 폴더 감시 폴링 주기(초)
poll_interval = 5

[stream_manager]
# mock 사용 여부 (true: 로컬 mock_uploads, false: 실제 Greengrass StreamManager → S3)
use_mock = true
# StreamManager 스트림 이름 (S3 export 스트림)
stream_name = CanBlackboxStream
# S3 업로드 완료 알림용 status 스트림 (use_mock=false 일 때만 사용)
status_stream_name = CanBlackboxStatusStream
# S3 버킷 (use_mock=false 일 때 필수)
s3_bucket =
# S3 오브젝트 키 prefix (날짜 파티션: can-logs/ → s3://버킷/can-logs/yyyy/MM/dd/파일.blf)
s3_prefix = can-logs/
